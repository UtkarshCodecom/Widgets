{
  "id": "clock_minimal",
  "name": "Minimal Clock",
  "designSize": "2x2",
  "background": {
    "gradientStart": "#1A1A2E",
    "gradientEnd": "#0F0F1A",
    "gradientAngle": 160,
    "cornerRadius": 0.18
  },
  "action": { "type": "open_activity", "packageName": "com.google.android.deskclock", "className": "com.android.deskclock.DeskClockTabActivity" },
  "components": [
    { "type": "shape", "frame": { "x": 0.06, "y": 0.06, "w": 0.88, "h": 0.88 },
