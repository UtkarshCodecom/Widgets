    { "type": "clock", "frame": { "x": 0.1, "y": 0.18, "w": 0.8, "h": 0.38 },
      "props": { "format": "HH:mm", "fontSize": 0.92, "align": "center", "bold": true, "color": "#FFFFFF" } },
    { "type": "divider", "frame": { "x": 0.3, "y": 0.58, "w": 0.4, "h": 0.01 },
      "props": { "color": "#30FFD700", "thickness": 0.06 } },
    { "type": "clock", "frame": { "x": 0.1, "y": 0.6, "w": 0.8, "h": 0.16 },
      "props": { "format": "EEE, MMM d", "fontSize": 0.72, "align": "center", "color": "#FFD700" } },
    { "type": "text", "frame": { "x": 0.1, "y": 0.78, "w": 0.8, "h": 0.1 },
      "props": { "text": "Tap to open clock", "fontSize": 0.55, "align": "center", "color": "#60FFFFFF" } }
  ]
}
