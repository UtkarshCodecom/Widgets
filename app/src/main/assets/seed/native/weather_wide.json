{
  "id": "weather_wide",
  "name": "Weather Wide",
  "designSize": "4x2",
  "background": {
    "gradientStart": "#0F2027",
    "gradientEnd": "#203A43",
    "gradientAngle": 135,
    "cornerRadius": 0.12
  },
  "action": { "type": "launch_app", "packageName": "com.google.android.apps.weatherradar" },
  "components": [
    { "type": "weather", "frame": { "x": 0.04, "y": 0.08, "w": 0.44, "h": 0.84 },
      "props": { "condition": "clear", "temp": 24, "location": "Your City", "high": 27, "low": 18, "unit": "°", "iconColor": "#FFD166", "textColor": "#FFFFFF", "subColor": "#90CAF9" } },
    { "type": "divider", "frame": { "x": 0.5, "y": 0.15, "w": 0.005, "h": 0.7 },
      "props": { "color": "#20FFFFFF", "thickness": 0.5 } },
    { "type": "text", "frame": { "x": 0.53, "y": 0.1, "w": 0.44, "h": 0.14 },
      "props": { "text": "Feels Like", "fontSize": 0.55, "align": "left", "color": "#80FFFFFF" } },
    { "type": "text", "frame": { "x": 0.53, "y": 0.24, "w": 0.44, "h": 0.22 },
      "props": { "text": "22°", "fontSize": 0.95, "align": "left", "bold": true, "color": "#FFFFFF" } },
    { "type": "progress_ring", "frame": { "x": 0.55, "y": 0.5, "w": 0.18, "h": 0.4 },
      "props": { "progress": 0.65, "progressColor": "#90CAF9", "trackColor": "#2090CAF9", "centerText": "65%", "textColor": "#FFFFFF", "thickness": 0.12, "textSize": 0.18 } },
    { "type": "text", "frame": { "x": 0.75, "y": 0.52, "w": 0.22, "h": 0.12 },
      "props": { "text": "Humidity", "fontSize": 0.5, "align": "left", "color": "#80FFFFFF" } },
    { "type": "text", "frame": { "x": 0.75, "y": 0.64, "w": 0.22, "h": 0.12 },
      "props": { "text": "Wind 12 km/h", "fontSize": 0.5, "align": "left", "color": "#80FFFFFF" } },
    { "type": "text", "frame": { "x": 0.75, "y": 0.76, "w": 0.22, "h": 0.12 },
      "props": { "text": "UV Index: 5", "fontSize": 0.5, "align": "left", "color": "#80FFFFFF" } }
  ]
}
