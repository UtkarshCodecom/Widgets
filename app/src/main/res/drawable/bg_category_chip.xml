<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neu_light_shadow" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neu_dark_shadow" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/yellow_accent_alpha_20" />
                    <corners android:radius="16dp" />
                    <stroke android:width="1dp" android:color="@color/yellow_accent" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:left="2dp" android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neu_dark_shadow_strong" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neu_light_shadow" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/dark_surface_variant" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
