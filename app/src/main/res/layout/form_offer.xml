<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/dark_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:contentPadding="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_neumorphic_small"
            android:orientation="vertical"
            android:padding="14dp">

            <EditText
                android:id="@+id/input_title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Offer Title"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/input_description"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Description"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/input_code"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Promo Code"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/input_discount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Discount Percent (e.g. 20)"
                android:inputType="number"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/input_image_url"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Image URL"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/input_active"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Active"
                android:textColor="@color/text_primary"
                android:thumbTint="@color/yellow_accent"
                android:trackTint="@color/yellow_accent_alpha_20" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
