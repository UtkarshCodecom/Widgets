<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dark_card"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="30dp"
    android:paddingEnd="28dp"
    android:paddingBottom="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Home Screen"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="128dp"
        android:layout_marginTop="26dp"
        android:background="@drawable/bg_admin_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/system_widget_preview"
            android:layout_width="120dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_widget_preview_black"
            android:gravity="center"
            android:text="ChatGPT   ✦ ◉ ◒"
            android:textColor="@color/yellow_accent"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/system_widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/text_tertiary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/system_widget_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_tertiary"
            android:textSize="15sp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Touch &amp; hold to place manually"
        android:textColor="@color/text_primary"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/add_auto_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="34dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?selectableItemBackground"
        android:gravity="center"
        android:text="Add automatically"
        android:textColor="@color/yellow_accent"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/cancel_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?selectableItemBackground"
        android:gravity="center"
        android:text="Cancel"
        android:textColor="@color/yellow_accent"
        android:textSize="19sp"
        android:textStyle="bold" />

</LinearLayout>
