<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cw_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Customize"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/cw_advanced"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Advanced"
            android:padding="10dp"
            android:textColor="?attr/colorOnSurface"
            android:background="?selectableItemBackground" />
    </LinearLayout>

    <!-- Live preview -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#11000000">

        <ImageView
            android:id="@+id/cw_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="16dp"
            android:contentDescription="Widget preview"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <!-- Controls -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <TextView style="@style/CwSectionLabel" android:text="Accent color" />
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none">
                <LinearLayout android:id="@+id/cw_accent_swatches" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" />
            </HorizontalScrollView>

            <TextView style="@style/CwSectionLabel" android:text="Text color" />
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none">
                <LinearLayout android:id="@+id/cw_text_swatches" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" />
            </HorizontalScrollView>

            <TextView style="@style/CwSectionLabel" android:text="Background" />
            <LinearLayout
                android:id="@+id/cw_bg_mode_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp" />

            <LinearLayout
                android:id="@+id/cw_bg_color_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView style="@style/CwSectionLabel" android:text="Background color" />
                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none">
                    <LinearLayout android:id="@+id/cw_bg_swatches" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" />
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cw_gradient_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView style="@style/CwSectionLabel" android:text="Gradient end color" />
                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none">
                    <LinearLayout android:id="@+id/cw_gradient_swatches" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" />
                </HorizontalScrollView>
            </LinearLayout>

            <TextView style="@style/CwSectionLabel" android:text="Corner radius" />
            <com.google.android.material.slider.Slider
                android:id="@+id/cw_corner_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.0"
                android:valueTo="0.5"
                android:stepSize="0.02"
                android:value="0.14" />

            <TextView style="@style/CwSectionLabel" android:text="Background opacity" />
            <com.google.android.material.slider.Slider
                android:id="@+id/cw_opacity_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                android:stepSize="0.05"
                android:value="1.0" />

            <TextView style="@style/CwSectionLabel" android:text="Font" />
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none">
                <LinearLayout android:id="@+id/cw_font_row" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="6dp" />
            </HorizontalScrollView>

            <TextView style="@style/CwSectionLabel" android:text="Photo" />
            <TextView
                android:id="@+id/cw_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Choose photo…"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:textColor="#FFFFFFFF"
                android:background="@drawable/bg_widget_tile" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/cw_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:textColor="?attr/colorOnSurface"
            android:background="?selectableItemBackground" />

        <TextView
            android:id="@+id/cw_add_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add to Home"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimary"
            android:background="@drawable/bg_premium_pill" />
    </LinearLayout>

</LinearLayout>
