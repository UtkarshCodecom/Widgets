<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Latest Version Code" app:boxStrokeColor="@color/yellow_accent">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/latest_version"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:hint="Min Supported Version"
        app:boxStrokeColor="@color/yellow_accent">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/min_version"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:hint="Force Update Message"
        app:boxStrokeColor="@color/yellow_accent">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/force_update_message"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:hint="Maintenance Message"
        app:boxStrokeColor="@color/yellow_accent">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/maintenance_message"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <Switch android:id="@+id/force_update_toggle" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="8dp"
        android:text="Force Update" android:textColor="@color/text_primary" />

    <Switch android:id="@+id/maintenance_toggle" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="8dp"
        android:text="Maintenance Mode" android:textColor="@color/text_primary" />

    <Button android:id="@+id/save_config_btn" android:layout_width="match_parent"
        android:layout_height="48dp" android:layout_marginTop="16dp"
        android:backgroundTint="@color/yellow_accent" android:text="@string/save"
        android:textColor="@color/black" android:textStyle="bold" app:cornerRadius="12dp" />

</LinearLayout>
