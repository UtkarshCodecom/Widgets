<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/dark_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:contentPadding="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_neumorphic"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/latest_version"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Latest Version Code"
                android:inputType="number"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/min_version"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Min Supported Version"
                android:inputType="number"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/force_update_message"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Force Update Message"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/maintenance_message"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_neumorphic_input"
                android:hint="Maintenance Message"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/force_update_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Force Update"
                android:textColor="@color/text_primary"
                android:thumbTint="@color/yellow_accent"
                android:trackTint="@color/yellow_accent_alpha_20" />

            <Switch
                android:id="@+id/maintenance_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Maintenance Mode"
                android:textColor="@color/text_primary"
                android:thumbTint="@color/yellow_accent"
                android:trackTint="@color/yellow_accent_alpha_20" />

            <Button
                android:id="@+id/save_config_btn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_neumorphic_button"
                android:gravity="center"
                android:text="Save Configuration"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
