<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout xmlns:app="http://schemas.android.com/apk/res-auto" style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Name" app:boxStrokeColor="@color/yellow_accent">
        <com.google.android.material.textfield.TextInputEditText xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/input_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout xmlns:app="http://schemas.android.com/apk/res-auto" style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:hint="Description"
        app:boxStrokeColor="@color/yellow_accent">
        <com.google.android.material.textfield.TextInputEditText xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/input_description"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout xmlns:app="http://schemas.android.com/apk/res-auto" style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:hint="Thumbnail URL"
        app:boxStrokeColor="@color/yellow_accent">
        <com.google.android.material.textfield.TextInputEditText xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/input_thumbnail_url"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <Switch xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/input_is_pro" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="8dp"
        android:text="Pro Theme" android:textColor="@color/text_primary" />

    <Switch xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/input_is_default" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="8dp"
        android:text="Default Theme" android:textColor="@color/text_primary" />

</LinearLayout>
