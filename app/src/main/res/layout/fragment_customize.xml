<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/dark_background"
        app:title="@string/theme_manager"
        app:titleTextColor="@color/text_primary" />

    <LinearLayout
        android:id="@+id/config_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:text="Themes"
            android:textColor="@color/yellow_accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/theme_recycler"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/dark_card"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:contentPadding="0dp">

            <Button
                android:id="@+id/toggle_studio_btn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_neumorphic_button"
                android:gravity="center"
                android:text="@string/widget_studio"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="14dp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Studio Panel -->
        <ScrollView
            android:id="@+id/studio_panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp">

                <!-- Preview Widget -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/preview_widget"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_neumorphic"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/preview_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Widget Preview"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Text &amp; Colors"
                    android:textColor="@color/yellow_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_neumorphic_small"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <EditText
                            android:id="@+id/text_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Text Color (e.g. #FFFFFF)"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/bg_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Background Color"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/accent_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Accent Color"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Typography"
                    android:textColor="@color/yellow_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_neumorphic_small"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Font Size"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/font_size_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="10"
                            android:valueTo="30"
                            android:value="14"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent" />

                        <EditText
                            android:id="@+id/font_family_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Font Family"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Layout"
                    android:textColor="@color/yellow_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_neumorphic_small"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Corner Radius"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/corner_radius_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="48"
                            android:value="16"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Padding"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/padding_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="48"
                            android:value="16"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Opacity"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/opacity_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="1"
                            android:value="1"
                            android:stepSize="0.1"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Borders &amp; Shadows"
                    android:textColor="@color/yellow_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_neumorphic_small"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Border Width"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/border_width_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="8"
                            android:value="0"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent" />

                        <EditText
                            android:id="@+id/border_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Border Color"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Shadow Radius"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/shadow_radius_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="24"
                            android:value="8"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent" />

                        <EditText
                            android:id="@+id/shadow_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Shadow Color"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Effects"
                    android:textColor="@color/yellow_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_neumorphic_small"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/glass_effect_switch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Glass Effect"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Glass Opacity"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/glass_opacity_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="1"
                            android:value="0.2"
                            android:stepSize="0.1"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/gradient_switch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Enable Gradient"
                            android:textColor="@color/text_primary" />

                        <EditText
                            android:id="@+id/gradient_start_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Gradient Start Color"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/gradient_end_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Gradient End Color"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/save_config_btn"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_neumorphic_button"
                        android:gravity="center"
                        android:text="@string/save_config"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp" />

                    <Button
                        android:id="@+id/reset_config_btn"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_neumorphic_small"
                        android:gravity="center"
                        android:text="@string/reset_config"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</LinearLayout>
