<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customize"
            android:textColor="@color/text_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Themes &amp; Widget Studio"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Section: App Themes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:text="App Theme"
                android:textColor="@color/yellow_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/theme_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:overScrollMode="never"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:background="@color/divider" />

            <!-- Section: Widget Studio -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Widget Studio"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Customize every detail"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/toggle_studio_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_premium_pill"
                    android:gravity="center"
                    android:paddingHorizontal="18dp"
                    android:text="Open"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Studio Panel (hidden by default) -->
            <LinearLayout
                android:id="@+id/studio_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Live Preview -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/preview_widget"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/glass_stroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/preview_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12:36"
                            android:textColor="@color/text_primary"
                            android:textSize="42sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/preview_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Widget Preview"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Colors Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="COLORS"
                    android:textColor="@color/yellow_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <EditText
                            android:id="@+id/text_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Text Color  #FFFFFF"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp"
                            android:inputType="text" />

                        <EditText
                            android:id="@+id/bg_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Background  #1A1A1A"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp"
                            android:inputType="text" />

                        <EditText
                            android:id="@+id/accent_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Accent Color  #FFD700"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp"
                            android:inputType="text" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Typography Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:text="TYPOGRAPHY"
                    android:textColor="@color/yellow_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Font Size"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/font_size_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="14"
                                android:textColor="@color/yellow_accent"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/font_size_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="10"
                            android:valueTo="30"
                            android:value="14"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent"
                            app:trackColorInactive="@color/dark_elevated" />

                        <EditText
                            android:id="@+id/font_family_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Font Family  e.g. monospace"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp"
                            android:inputType="text" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Layout Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:text="LAYOUT"
                    android:textColor="@color/yellow_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Corner Radius"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/corner_radius_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="16"
                                android:textColor="@color/yellow_accent"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/corner_radius_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="48"
                            android:value="16"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent"
                            app:trackColorInactive="@color/dark_elevated" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Padding"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/padding_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="16"
                                android:textColor="@color/yellow_accent"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/padding_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="48"
                            android:value="16"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent"
                            app:trackColorInactive="@color/dark_elevated" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Opacity"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/opacity_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100%"
                                android:textColor="@color/yellow_accent"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/opacity_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0.0"
                            android:valueTo="1.0"
                            android:value="1.0"
                            android:stepSize="0.05"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent"
                            app:trackColorInactive="@color/dark_elevated" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Borders & Shadows -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:text="BORDERS &amp; SHADOWS"
                    android:textColor="@color/yellow_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Border Width"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/border_width_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/yellow_accent"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/border_width_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="8"
                            android:value="0"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent"
                            app:trackColorInactive="@color/dark_elevated" />

                        <EditText
                            android:id="@+id/border_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Border Color  #33FFFFFF"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp"
                            android:inputType="text" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Shadow Radius"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/shadow_radius_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8"
                                android:textColor="@color/yellow_accent"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/shadow_radius_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="24"
                            android:value="8"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent"
                            app:trackColorInactive="@color/dark_elevated" />

                        <EditText
                            android:id="@+id/shadow_color_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Shadow Color  #40000000"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp"
                            android:inputType="text" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Effects -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:text="EFFECTS"
                    android:textColor="@color/yellow_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/dark_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/glass_effect_switch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Glass / Frosted Effect"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Glass Opacity"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/glass_opacity_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20%"
                                android:textColor="@color/yellow_accent"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/glass_opacity_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0.0"
                            android:valueTo="1.0"
                            android:value="0.0"
                            android:stepSize="0.05"
                            app:thumbColor="@color/yellow_accent"
                            app:trackColorActive="@color/yellow_accent"
                            app:trackColorInactive="@color/dark_elevated" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/gradient_switch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Enable Gradient Background"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/gradient_start_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Gradient Start  #FFD700"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp"
                            android:inputType="text" />

                        <EditText
                            android:id="@+id/gradient_end_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_neumorphic_input"
                            android:hint="Gradient End  #FF8C00"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_tertiary"
                            android:textSize="14sp"
                            android:inputType="text" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/save_config_btn"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_premium_pill"
                        android:gravity="center"
                        android:text="Save Style"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/reset_config_btn"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_neumorphic_small"
                        android:gravity="center"
                        android:text="Reset"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
