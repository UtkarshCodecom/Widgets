<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Widgets" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/yellow_accent</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/yellow_accent_alpha_20</item>
        <item name="colorOnPrimaryContainer">@color/yellow_accent_light</item>
        <item name="colorSecondary">@color/yellow_accent_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/yellow_accent_alpha_10</item>
        <item name="colorOnSecondaryContainer">@color/yellow_accent</item>
        <item name="colorTertiary">@color/yellow_accent_light</item>
        <item name="colorOnTertiary">@color/black</item>
        <item name="colorError">@color/error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOnErrorContainer">@color/error</item>
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/dark_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/divider</item>
        <item name="colorOutlineVariant">@color/yellow_accent_alpha_20</item>

        <!-- Status bar / nav bar -->
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Allow content to draw into cutout area — MainActivity handles insets -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>

        <item name="elevationOverlayEnabled">false</item>

        <!-- Neumorphic: remove default card elevation -->
        <item name="cardViewStyle">@style/Widget.Widgets.Card.Neumorphic</item>
    </style>

    <!-- ===== THEME VARIANTS ===== -->

    <!-- Default: Dark Gold -->
    <style name="Theme.Widgets" parent="Base.Theme.Widgets">
        <item name="colorPrimary">#FFD700</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryContainer">#33FFD700</item>
        <item name="colorSecondary">#FF8C00</item>
        <item name="android:colorBackground">#0D0D0D</item>
        <item name="colorSurface">#1A1A1A</item>
        <item name="colorOnSurface">#FFFFFFFF</item>
        <item name="android:statusBarColor">#0D0D0D</item>
        <item name="android:navigationBarColor">#0D0D0D</item>
    </style>

    <!-- Midnight Blue -->
    <style name="Theme.Widgets.MidnightBlue" parent="Base.Theme.Widgets">
        <item name="colorPrimary">#00D4FF</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryContainer">#2200D4FF</item>
        <item name="colorSecondary">#448AFF</item>
        <item name="android:colorBackground">#050D14</item>
        <item name="colorSurface">#0D1B2A</item>
        <item name="colorOnSurface">#FFFFFFFF</item>
        <item name="android:statusBarColor">#050D14</item>
        <item name="android:navigationBarColor">#050D14</item>
    </style>

    <!-- Rose Quartz -->
    <style name="Theme.Widgets.Rose" parent="Base.Theme.Widgets">
        <item name="colorPrimary">#FF6B9D</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryContainer">#22FF6B9D</item>
        <item name="colorSecondary">#AB47BC</item>
        <item name="android:colorBackground">#0F0709</item>
        <item name="colorSurface">#1C1214</item>
        <item name="colorOnSurface">#FFFFFFFF</item>
        <item name="android:statusBarColor">#0F0709</item>
        <item name="android:navigationBarColor">#0F0709</item>
    </style>

    <!-- Forest Green -->
    <style name="Theme.Widgets.Forest" parent="Base.Theme.Widgets">
        <item name="colorPrimary">#00E676</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryContainer">#2200E676</item>
        <item name="colorSecondary">#1DE9B6</item>
        <item name="android:colorBackground">#040F08</item>
        <item name="colorSurface">#0A1A0F</item>
        <item name="colorOnSurface">#FFFFFFFF</item>
        <item name="android:statusBarColor">#040F08</item>
        <item name="android:navigationBarColor">#040F08</item>
    </style>

    <!-- AMOLED Black -->
    <style name="Theme.Widgets.AMOLED" parent="Base.Theme.Widgets">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryContainer">#22FFFFFF</item>
        <item name="colorSecondary">#B0BEC5</item>
        <item name="android:colorBackground">#000000</item>
        <item name="colorSurface">#0A0A0A</item>
        <item name="colorOnSurface">#FFFFFFFF</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>

    <style name="Theme.Widgets.Translucent" parent="Theme.Widgets">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.Widgets.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="contentPadding">16dp</item>
        <item name="android:background">@drawable/bg_neumorphic</item>
    </style>

    <style name="Widget.Widgets.Card.Neumorphic" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:background">@drawable/bg_neumorphic</item>
    </style>

    <style name="Widget.Widgets.Card.Neumorphic.Small" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:background">@drawable/bg_neumorphic_small</item>
    </style>

    <style name="Widget.Widgets.Button.Yellow" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Widgets.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Widgets.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/dark_surface_variant</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

    <style name="Widget.Widgets.NavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/colorPrimaryContainer</item>
        <item name="android:width">64dp</item>
        <item name="android:height">34dp</item>
        <item name="marginHorizontal">8dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
    </style>
</resources>